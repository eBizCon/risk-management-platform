# Database
DATABASE_URL=postgresql://risk:risk@localhost:5432/risk_management

# Session encryption (32+ char random string for AES-256-GCM)
SESSION_SECRET=change-me-to-a-random-32-char-string!!

# OIDC / Keycloak
OIDC_ISSUER=http://localhost:8081/realms/risk-management
OIDC_CLIENT_ID=risk-management-platform
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
OIDC_SCOPE=openid profile email
OIDC_ROLES_CLAIM_PATH=realm_access.roles

# Backend service URLs (proxied by SvelteKit BFF)
RISK_MANAGEMENT_API_URL=http://localhost:5227
CUSTOMER_SERVICE_URL=http://localhost:5001

# API Keys (shared between SvelteKit BFF and backend services)
SERVICE_API_KEY=dev-api-key-12345

# Optional (only if you override Keycloak admin in docker-compose)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
